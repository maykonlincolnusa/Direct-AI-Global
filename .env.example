APP_NAME=direct-platform
APP_VERSION=1.0.0

NODE_ENV=development
CLOUD_PROVIDER=local
API_HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
CONFIG_ENV_FILE=

REQUEST_BODY_LIMIT=1048576
TRUST_PROXY=0
CORS_ORIGINS=*

DEFAULT_LOCALE=en-US
DEFAULT_CURRENCY=USD
APP_REGION=US

MONGO_URI=mongodb://mongodb:27017/direct-core
MONGO_DB_PREFIX=direct
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://rabbitmq:5672

JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
JWT_ISSUER=direct-platform
JWT_AUDIENCE=direct-clients
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_SECONDS=2592000

RATE_LIMIT_POINTS=1500
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_POINTS=20
AUTH_RATE_LIMIT_WINDOW_MS=60000

TOKEN_BUDGET_BASE=1200
TOKEN_BUDGET_PER_REQUEST=900
TOKEN_BUDGET_PER_USER=3000
TOKEN_BUDGET_PER_TENANT=25000
TOKEN_BUDGET_PER_MODULE=5000

REQUEST_TIMEOUT_MS=10000
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=200
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RESET_MS=15000

OTEL_ENABLED=false
OTEL_SERVICE_NAME=direct-platform-api
OTEL_EXPORTER_OTLP_ENDPOINT=

OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_REASONING_ENABLED=true
OPENROUTER_APP_NAME=Direct
OPENROUTER_REFERER=http://localhost:3000

EMBEDDING_PROVIDER=deterministic
EMBEDDING_STRICT=false
EMBEDDING_DIMENSIONS=128
OPENROUTER_EMBEDDINGS_URL=https://openrouter.ai/api/v1/embeddings
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

VECTOR_STORE_PROVIDER=file
VECTOR_DB_URL=
VECTOR_DB_API_KEY=

STORAGE_PROVIDER=local
STORAGE_BUCKET=direct-assets
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=
STORAGE_BASE_PATH=.direct-context-data/storage

FEATURE_FLAGS_JSON={}

AWS_REGION=us-east-1
AZURE_LOCATION=eastus
GCP_REGION=us-central1
RAILWAY_ENVIRONMENT=development
