{
  "family": "direct-platform-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::<account-id>:role/direct-platform-api-execution",
  "taskRoleArn": "arn:aws:iam::<account-id>:role/direct-platform-api-runtime",
  "containerDefinitions": [
    {
      "name": "platform-api",
      "image": "<account-id>.dkr.ecr.<region>.amazonaws.com/direct-platform-api:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "CLOUD_PROVIDER", "value": "aws" },
        { "name": "PORT", "value": "3000" },
        { "name": "APP_REGION", "value": "US" },
        { "name": "LOG_LEVEL", "value": "info" },
        { "name": "DEFAULT_LOCALE", "value": "en-US" },
        { "name": "DEFAULT_CURRENCY", "value": "USD" },
        { "name": "RATE_LIMIT_POINTS", "value": "1500" },
        { "name": "RATE_LIMIT_WINDOW_MS", "value": "60000" },
        { "name": "TOKEN_BUDGET_BASE", "value": "1200" }
      ],
      "secrets": [
        {
          "name": "JWT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:direct/JWT_SECRET"
        },
        {
          "name": "MONGO_URI",
          "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:direct/MONGO_URI"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:direct/REDIS_URL"
        },
        {
          "name": "RABBITMQ_URL",
          "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:direct/RABBITMQ_URL"
        },
        {
          "name": "OPENROUTER_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:direct/OPENROUTER_API_KEY"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:3000/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 20
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/direct-platform-api",
          "awslogs-region": "<region>",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
