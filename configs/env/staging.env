NODE_ENV=production
CLOUD_PROVIDER=aws
LOG_LEVEL=info

MONGO_URI=mongodb://staging-mongodb:27017/direct-core
REDIS_URL=redis://staging-redis:6379
RABBITMQ_URL=amqp://staging-rabbitmq:5672

JWT_SECRET=staging-override-in-secret-manager
JWT_REFRESH_SECRET=staging-refresh-override-in-secret-manager
JWT_ISSUER=direct-platform-staging
JWT_AUDIENCE=direct-clients-staging
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_SECONDS=2592000

OTEL_ENABLED=true
OTEL_SERVICE_NAME=direct-platform-api-staging
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces

EMBEDDING_PROVIDER=openrouter
VECTOR_STORE_PROVIDER=http
VECTOR_DB_URL=https://staging-vector-db.internal
