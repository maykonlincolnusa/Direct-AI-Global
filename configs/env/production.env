NODE_ENV=production
CLOUD_PROVIDER=aws
LOG_LEVEL=info

MONGO_URI=mongodb://prod-mongodb:27017/direct-core
REDIS_URL=redis://prod-redis:6379
RABBITMQ_URL=amqp://prod-rabbitmq:5672

JWT_SECRET=override-in-secret-manager
JWT_REFRESH_SECRET=override-refresh-in-secret-manager
JWT_ISSUER=direct-platform
JWT_AUDIENCE=direct-clients
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_SECONDS=2592000

OTEL_ENABLED=true
OTEL_SERVICE_NAME=direct-platform-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces

STORAGE_PROVIDER=s3
STORAGE_BUCKET=direct-prod-assets
STORAGE_REGION=us-east-1

EMBEDDING_PROVIDER=openrouter
VECTOR_STORE_PROVIDER=http
VECTOR_DB_URL=https://vector-db.internal
